FROM python:3.12-slim AS base

WORKDIR /app

# Install dependencies
COPY pyproject.toml .
RUN pip install --no-cache-dir \
    "mind-mem>=1.9.0" \
    "httpx>=0.27" \
    "fastmcp>=2.0" \
    "uvicorn>=0.30" \
    "starlette>=0.40"

# Copy application code
COPY engine/ engine/
COPY mcp_server/ mcp_server/

ENV PORT=8080
EXPOSE 8080

CMD ["python", "-m", "mcp_server.server"]
