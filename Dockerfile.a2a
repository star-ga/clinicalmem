FROM python:3.12-slim AS base

WORKDIR /app

# Install dependencies
COPY pyproject.toml .
RUN pip install --no-cache-dir \
    "mind-mem>=1.9.0" \
    "httpx>=0.27" \
    "google-adk>=1.0" \
    "a2a-sdk>=0.2" \
    "uvicorn>=0.30" \
    "starlette>=0.40"

# Copy application code
COPY engine/ engine/
COPY a2a_agent/ a2a_agent/
COPY tests/fixtures/ tests/fixtures/

ENV PORT=8080
ENV DEMO_MODE=true
EXPOSE 8080

CMD ["uvicorn", "a2a_agent.app:a2a_app", "--host", "0.0.0.0", "--port", "8080"]
